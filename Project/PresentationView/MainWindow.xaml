<Window x:Class="PresentationView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Billiard Simulation" Height="550" Width="800" Background="#FF333333">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FFDDDDDD" BorderBrush="Black" BorderThickness="0,0,0,2" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Number of balls: " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                <TextBox Width="50" Text="{Binding BallCount, UpdateSourceTrigger=PropertyChanged}" 
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,15,0"/>

                <Button Content="Start" Command="{Binding StartCommand}" Width="80" Height="30" Margin="5,0"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="80" Height="30" Margin="5,0"/>
            </StackPanel>
        </Border>

        <Border Margin="15" BorderBrush="#FF111111" BorderThickness="3" CornerRadius="5">
            <ItemsControl ItemsSource="{Binding Balls}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="#FF006600" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="20" Height="20" Fill="Orange" Stroke="Black" StrokeThickness="1">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </DockPanel>
</Window>